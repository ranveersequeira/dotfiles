# ============================================================
# TMUX AUTO START
# ============================================================

if [[ "$TERM_PROGRAM" == "ghostty" ]] && command -v tmux >/dev/null 2>&1; then
  if [[ -z "$TMUX" ]]; then
    tmux attach -t main || tmux new -s main
  fi
fi

# ============================================================
# TMUX + WORKTREE HELPERS
# ============================================================

_tmux_session_name_from_pwd() {
  local root common repo worktree subdir name

  if root=$(git rev-parse --show-toplevel 2>/dev/null); then
    common=$(git rev-parse --git-common-dir 2>/dev/null)
    repo=$(basename "$common")
    worktree=$(basename "$root")
    subdir="${PWD#$root}"

    if [[ "$worktree" == "$repo" ]]; then
      name="$repo"
    else
      name="$repo-$worktree"
    fi

    if [[ -n "$subdir" && "$subdir" != "$PWD" ]]; then
      subdir=$(printf '%s' "$subdir" | sed 's|^/||; s|/|-|g')
      [[ -n "$subdir" ]] && name="$name-$subdir"
    fi
  else
    name="$(basename "$(dirname "$PWD")")-$(basename "$PWD")"
  fi

  printf '%s' "$name" \
    | sed 's|[[:space:]/:]|-|g; s|-\\{2,\\}|-|g; s|^-||; s|-$||'
}

_wt_tmux_rename() {
  [[ -z "$TMUX" ]] && return

  local cmd
  cmd="$(tmux display-message -p '#{pane_current_command}' 2>/dev/null)"

  if [[ -n "$cmd" ]]; then
    tmux rename-window "$cmd" 2>/dev/null
  fi
}

autoload -Uz add-zsh-hook
add-zsh-hook chpwd _wt_tmux_rename
add-zsh-hook precmd _wt_tmux_rename

# ------------------------------------------------------------
# Worktree + tmux helper
# ------------------------------------------------------------
tw() {
  local name is_git
  name="$(basename "$PWD")"

  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    is_git=1
    name="$(basename "$(git rev-parse --show-toplevel)")"
  else
    is_git=0
  fi

  if tmux has-session -t "$name" 2>/dev/null; then
    tmux attach -t "$name"
    return
  fi

  tmux new-session -d -s "$name"

  if [[ "$is_git" -eq 1 ]]; then
    tmux split-window -h -t "$name":1
    tmux select-layout -t "$name":1 even-horizontal
  fi

  tmux attach -t "$name"
}

wtm() {
  if ! command -v wt >/dev/null 2>&1; then
    echo "wt command not found"
    return 1
  fi

  command wt "$@" || return
  tw
}

alias w="wtm"
