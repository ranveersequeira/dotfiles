
# ============================================================
# ZSH CONFIG
# ============================================================

# ------------------------------------------------------------
# Paths: Homebrew first
# ------------------------------------------------------------
export PATH="/opt/homebrew/bin:$PATH"

# ------------------------------------------------------------
# Secrets
# Keep tokens out of this file.
# Put them in: ~/.config/secrets/env
# ------------------------------------------------------------
[[ -f "$HOME/.config/secrets/env" ]] && source "$HOME/.config/secrets/env"

# ------------------------------------------------------------
# Zap plugin manager
# ------------------------------------------------------------
ZAP_PATH="${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh"

if [[ -f "$ZAP_PATH" ]]; then
  source "$ZAP_PATH"

  plug "zap-zsh/zap-prompt"
  plug "zap-zsh/supercharge"
  plug "zsh-users/zsh-autosuggestions"
  plug "zsh-users/zsh-syntax-highlighting"
fi

# ------------------------------------------------------------
# Vi mode
# ------------------------------------------------------------
set -o vi
export KEYTIMEOUT=5

bindkey -M viins 'jj' vi-cmd-mode
bindkey '^?' backward-delete-char
bindkey '^H' backward-delete-char

# Cursor shape:
# block in normal mode, beam in insert mode
function zle-keymap-select {
  if [[ "$KEYMAP" == vicmd ]]; then
    echo -ne '\e[1 q'
  else
    echo -ne '\e[5 q'
  fi
}

zle -N zle-keymap-select
echo -ne '\e[5 q'

# ------------------------------------------------------------
# Completion system
# ------------------------------------------------------------
autoload -Uz compinit
compinit -C

# ------------------------------------------------------------
# Carapace completions
# ------------------------------------------------------------
if command -v carapace >/dev/null 2>&1; then
  export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
  zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
  eval "$(carapace _carapace zsh)"
fi

# ------------------------------------------------------------
# Editor
# ------------------------------------------------------------
export EDITOR="nvim"
export LAUNCH_EDITOR="code"

# ------------------------------------------------------------
# Android / Java
# ------------------------------------------------------------
export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"

export ANDROID_HOME="$HOME/Library/Android/sdk"
export ANDROID_SDK_ROOT="$ANDROID_HOME"

export PATH="$ANDROID_SDK_ROOT/emulator:$ANDROID_SDK_ROOT/platform-tools:$ANDROID_SDK_ROOT/tools:$PATH"

# ------------------------------------------------------------
# Bun
# ------------------------------------------------------------
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

[[ -s "$HOME/.bun/_bun" ]] && source "$HOME/.bun/_bun"

# ------------------------------------------------------------
# pnpm
# ------------------------------------------------------------
export PNPM_HOME="$HOME/.local/share/pnpm"

case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

# ------------------------------------------------------------
# Rust / Cargo
# ------------------------------------------------------------
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# ------------------------------------------------------------
# Node via fnm
# ------------------------------------------------------------
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd)"
fi

# ------------------------------------------------------------
# Zoxide
# ------------------------------------------------------------
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# ------------------------------------------------------------
# Television fuzzy finder
# ------------------------------------------------------------
if command -v tv >/dev/null 2>&1; then
  eval "$(tv init zsh)"
fi

# ------------------------------------------------------------
# tmuxifier
# ------------------------------------------------------------
export PATH="$HOME/.tmuxifier/bin:$PATH"
# eval "$(tmuxifier init -)"

# ------------------------------------------------------------
# Antigravity
# ------------------------------------------------------------
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# ------------------------------------------------------------
# Agent / tool env
# ------------------------------------------------------------
export ENABLE_TOOL_SEARCH="auto:5"
export ENABLE_LSP_TOOL=1
export AGENTIFY_MEMPALACE_CMD="$HOME/.local/bin/mempalace"

# ------------------------------------------------------------
# Worktree tool shell integration
# ------------------------------------------------------------
if command -v wt >/dev/null 2>&1; then
  eval "$(command wt config shell init zsh)"
fi

